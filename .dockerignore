# .dockerignore for the tomlkit commit-image build.
# Bake in the FULL repo (including .git history — the grader uses it); drop only local build
# artifacts and editor/OS cruft. This is a dev image, not a minimal one.

# Local Python build artifacts / caches (build.sh produces its outputs under /mayhem at build time).
**/__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
dist/
.coverage

# Editor / OS noise
.DS_Store
*.swp
*~
